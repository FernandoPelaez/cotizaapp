generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?

  profileType      ProfileType?
  profileCompleted Boolean      @default(false)
  onboardingStep   Int          @default(1)

  quotesUsed       Int     @default(0)
  trialQuotesLimit Int     @default(5)
  trialBlocked     Boolean @default(false)

  planId String?
  plan   Plan?   @relation(fields: [planId], references: [id])

  quotes      Quote[]
  quoteEvents QuoteEvent[]
  profile     Profile?
  settings    Settings?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts Account[]
  sessions Session[]

  @@index([planId])
  @@index([profileType])
  @@index([profileCompleted])
  @@index([trialBlocked])
}

model Settings {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  confirmDelete Boolean @default(true)
  confirmPDF    Boolean @default(true)
  autoSave      Boolean @default(true)

  autoDownloadPDF Boolean @default(false)
  openPDFNewTab   Boolean @default(true)

  notifyLimit         Boolean @default(true)
  systemConfirmations Boolean @default(true)

  notes      String?
  conditions String?
  validity   String?
  fileName   String? @default("Cotizacion")

  defaultSendChannel SendChannel @default(PDF)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Profile {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  phone String?
  rfc   String?

  oficio       String?
  businessName String?
  razonSocial  String?
  description  String?

  specialties String[] @default([])

  city            String?
  state           String?
  direccionFiscal String?

  logoUrl    String?
  themeColor String?

  showPhone   Boolean @default(true)
  showAddress Boolean @default(false)

  businessModel BusinessModel?
  hasFiscalData Boolean?
  taxMode       TaxMode?
  billingMode   BillingMode?
  depositPolicy DepositPolicy?

  defaultTemplateId String?
  defaultTemplate   Template? @relation("DefaultProfileTemplate", fields: [defaultTemplateId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessModel])
  @@index([taxMode])
  @@index([defaultTemplateId])
}

model Account {
  id                String @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String

  refresh_token String?
  access_token  String?
  expires_at    Int?
  token_type    String?
  scope         String?
  id_token      String?
  session_state String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Plan {
  id           String  @id @default(cuid())
  name         String
  price        Float
  maxQuotes    Int
  whatsappSend Boolean @default(false)

  users User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Template {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?

  category      String?
  profileType   ProfileType?
  businessModel BusinessModel?

  isPremium Boolean @default(false)

  previewUrl String?
  html       String

  quotes            Quote[]
  defaultForProfile Profile[] @relation("DefaultProfileTemplate")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isPremium])
  @@index([profileType])
  @@index([businessModel])
}

model Quote {
  id          String  @id @default(cuid())
  title       String
  description String?

  clientName    String
  clientPhone   String?
  clientEmail   String?
  clientAddress String?
  clientRFC     String?

  subtotal Float
  discount Float @default(0)
  tax      Float @default(0)
  total    Float

  validUntil DateTime?
  notes      String?

  status      QuoteStatus @default(DRAFT)
  sendChannel SendChannel @default(PDF)
  sentAt      DateTime?

  responseToken     String?      @unique
  responseExpiresAt DateTime?
  respondedAt       DateTime?
  responseChannel   SendChannel?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  templateId String?
  template   Template? @relation(fields: [templateId], references: [id])

  items  QuoteItem[]
  events QuoteEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([templateId])
  @@index([createdAt])
  @@index([status])
  @@index([sendChannel])
  @@index([responseToken])
  @@index([responseExpiresAt])
}

model QuoteItem {
  id String @id @default(cuid())

  name     String
  quantity Int
  price    Float
  total    Float

  quoteId String
  quote   Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
}

model QuoteEvent {
  id String @id @default(cuid())

  quoteId String
  quote   Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type    QuoteEventType
  title   String
  message String?

  isRead Boolean   @default(false)
  readAt DateTime?

  metadata Json?

  createdAt DateTime @default(now())

  @@index([quoteId])
  @@index([userId])
  @@index([type])
  @@index([isRead])
  @@index([createdAt])
  @@index([userId, isRead, createdAt])
}

enum QuoteStatus {
  DRAFT
  SENT
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

enum QuoteEventType {
  QUOTE_SENT
  QUOTE_ACCEPTED
  QUOTE_REJECTED
  QUOTE_EXPIRED
}

enum ProfileType {
  INDEPENDIENTE
  NEGOCIO
}

enum BusinessModel {
  PRODUCTOS
  SERVICIOS
  AMBOS
}

enum TaxMode {
  IVA_INCLUIDO
  IVA_DESGLOSADO
  SIN_IVA
}

enum BillingMode {
  PROYECTO
  HORA
}

enum DepositPolicy {
  SIEMPRE
  AVECES
  NUNCA
}

enum SendChannel {
  PDF
  WHATSAPP
}
