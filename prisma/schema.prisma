generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String       @id @default(cuid())
  name             String?
  email            String       @unique
  emailVerified    DateTime?
  image            String?
  password         String?
  profileCompleted Boolean      @default(false)
  planId           String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  onboardingStep   Int          @default(1)
  quotesUsed       Int          @default(0)
  trialBlocked     Boolean      @default(false)
  trialQuotesLimit Int          @default(5)
  profileType      ProfileType?
  accounts         Account[]
  profile          Profile?
  quotes           Quote[]
  quoteEvents      QuoteEvent[]
  sessions         Session[]
  settings         Settings?
  plan             Plan?        @relation(fields: [planId], references: [id])

  @@index([planId])
  @@index([profileType])
  @@index([profileCompleted])
  @@index([trialBlocked])
}

model Settings {
  id                  String            @id @default(cuid())
  userId              String            @unique
  confirmDelete       Boolean           @default(true)
  confirmPDF          Boolean           @default(true)
  autoSave            Boolean           @default(true)
  autoDownloadPDF     Boolean           @default(false)
  openPDFNewTab       Boolean           @default(true)
  notifyLimit         Boolean           @default(true)
  systemConfirmations Boolean           @default(true)
  notes               String?
  conditions          String?
  validity            String?
  fileName            String?           @default("Cotizacion")
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  defaultSendChannel  SendChannel       @default(PDF)
  brandColor          String            @default("#1b3d7a")
  cardStyle           ThemeCardStyle    @default(SUAVE)
  densityStyle        ThemeDensityStyle @default(COMODA)
  fontFamily          ThemeFontFamily   @default(GEIST)
  radiusStyle         ThemeRadiusStyle  @default(MEDIO)
  shadowStyle         ThemeShadowStyle  @default(SUAVE)
  themeMode           ThemeMode         @default(SISTEMA)
  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Profile {
  id                String         @id @default(cuid())
  userId            String         @unique
  phone             String?
  oficio            String?
  businessName      String?
  description       String?
  city              String?
  state             String?
  logoUrl           String?
  themeColor        String?
  showPhone         Boolean        @default(true)
  showAddress       Boolean        @default(false)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  billingMode       BillingMode?
  businessModel     BusinessModel?
  defaultTemplateId String?
  depositPolicy     DepositPolicy?
  hasFiscalData     Boolean?
  taxMode           TaxMode?
  defaultTemplate   Template?      @relation("DefaultProfileTemplate", fields: [defaultTemplateId], references: [id])
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([businessModel])
  @@index([taxMode])
  @@index([defaultTemplateId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Plan {
  id           String   @id @default(cuid())
  name         String
  price        Float
  maxQuotes    Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  whatsappSend Boolean  @default(false)
  users        User[]
}

model Template {
  id                String         @id @default(cuid())
  name              String         @unique
  description       String?
  category          String?
  isPremium         Boolean        @default(false)
  previewUrl        String?
  html              String
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  businessModel     BusinessModel?
  profileType       ProfileType?
  defaultForProfile Profile[]      @relation("DefaultProfileTemplate")
  quotes            Quote[]

  @@index([isPremium])
  @@index([profileType])
  @@index([businessModel])
}

model Quote {
  id                String       @id @default(cuid())
  title             String
  description       String?
  clientName        String
  subtotal          Float
  discount          Float        @default(0)
  tax               Float        @default(0)
  total             Float
  validUntil        DateTime?
  notes             String?
  status            QuoteStatus  @default(DRAFT)
  userId            String
  templateId        String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  clientAddress     String?
  clientEmail       String?
  clientPhone       String?
  clientRFC         String?
  sendChannel       SendChannel  @default(PDF)
  sentAt            DateTime?
  respondedAt       DateTime?
  responseChannel   SendChannel?
  responseExpiresAt DateTime?
  responseToken     String?      @unique
  template          Template?    @relation(fields: [templateId], references: [id])
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  events            QuoteEvent[]
  items             QuoteItem[]

  @@index([userId])
  @@index([templateId])
  @@index([createdAt])
  @@index([status])
  @@index([sendChannel])
  @@index([responseToken])
  @@index([responseExpiresAt])
}

model QuoteItem {
  id       String @id @default(cuid())
  name     String
  quantity Int
  price    Float
  total    Float
  quoteId  String
  quote    Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
}

model QuoteEvent {
  id        String         @id @default(cuid())
  quoteId   String
  userId    String
  type      QuoteEventType
  title     String
  message   String?
  isRead    Boolean        @default(false)
  readAt    DateTime?
  metadata  Json?
  createdAt DateTime       @default(now())
  quote     Quote          @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([quoteId])
  @@index([userId])
  @@index([type])
  @@index([isRead])
  @@index([createdAt])
  @@index([userId, isRead, createdAt])
}

enum QuoteStatus {
  DRAFT
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
  SENT
}

enum QuoteEventType {
  QUOTE_SENT
  QUOTE_ACCEPTED
  QUOTE_REJECTED
  QUOTE_EXPIRED
}

enum ProfileType {
  INDEPENDIENTE
  NEGOCIO
}

enum BusinessModel {
  PRODUCTOS
  SERVICIOS
  AMBOS
}

enum TaxMode {
  IVA_INCLUIDO
  IVA_DESGLOSADO
  SIN_IVA
}

enum BillingMode {
  PROYECTO
  HORA
}

enum DepositPolicy {
  SIEMPRE
  AVECES
  NUNCA
}

enum SendChannel {
  PDF
  WHATSAPP
}

enum ThemeMode {
  CLARO
  OSCURO
  SISTEMA
}

enum ThemeFontFamily {
  GEIST
  INTER
  POPPINS
  OUTFIT
  MANROPE
}

enum ThemeCardStyle {
  SUAVE
  SOLIDO
  BORDEADO
  ELEVADO
}

enum ThemeRadiusStyle {
  PEQUENO
  MEDIO
  GRANDE
}

enum ThemeShadowStyle {
  SIN_SOMBRA
  SUAVE
  MEDIA
  MARCADA
}

enum ThemeDensityStyle {
  COMPACTA
  COMODA
  AMPLIA
}
